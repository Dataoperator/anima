type Error = variant {
    Configuration : text;
    NotFound;
    NotAuthorized;
    AlreadyInitialized;
    External : text;
};

type EventType = variant {
    Initial;
    UserInteraction;
    AutonomousThought;
    EmotionalResponse;
    LearningMoment;
    RelationshipDevelopment;
};

type Memory = record {
    timestamp: nat64;
    event_type: EventType;
    description: text;
    emotional_impact: float32;
    importance_score: float32;
    keywords: vec text;
};

type DevelopmentalStage = variant {
    Initial;
    Beginner;
    Intermediate;
    Advanced;
    Expert;
};

type NFTPersonality = record {
    traits: vec record { text; float32; };
    memories: vec Memory;
    creation_time: nat64;
    interaction_count: nat64;
    growth_level: nat32;
    developmental_stage: DevelopmentalStage;
    hash: opt text;
};

type Anima = record {
    owner: principal;
    name: text;
    personality: NFTPersonality;
    creation_time: nat64;
    last_interaction: nat64;
    autonomous_enabled: bool;
};

type InteractionResult = record {
    response: text;
    personality_updates: vec record { text; float32; };
    memory: Memory;
    is_autonomous: bool;
};

type UserState = variant {
    NotInitialized;
    Initialized : Anima;
};

service : {
    create_anima: (text) -> (Result<principal, Error>) query;
    get_anima: (principal) -> (Result<Anima, Error>) query;
    interact: (principal, text) -> (Result<InteractionResult, Error>);
    set_openai_config: (text) -> (Result<null, Error>);
    get_user_state: (opt principal) -> (UserState) query;
}