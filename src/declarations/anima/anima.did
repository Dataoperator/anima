type EventType = variant {
    Initial;
    UserInteraction;
    AutonomousThought;
    EmotionalResponse;
    LearningMoment;
    RelationshipDevelopment;
};

type Memory = record {
    timestamp : nat64;
    event_type : EventType;
    description : text;
    emotional_impact : float32;
    importance_score : float32;
    keywords : vec text;
};

type NFTPersonality = record {
    traits : vec record { text; float32; };
    memories : vec Memory;
    creation_time : nat64;
    interaction_count : nat64;
    growth_level : nat32;
    developmental_stage : DevelopmentalStage;
    hash : opt text;
};

type DevelopmentalStage = variant {
    Initial;
    Beginner;
    Intermediate;
    Advanced;
    Expert;
};

type Anima = record {
    owner : principal;
    name : text;
    personality : NFTPersonality;
    creation_time : nat64;
    last_interaction : nat64;
    autonomous_enabled : bool;
};

type InteractionResult = record {
    response : text;
    personality_updates : vec record { text; float32; };
    memory : Memory;
    is_autonomous : bool;
};

type Error = variant {
    NotFound;
    NotAuthorized;
    Configuration : text;
    External : text;
};

type InitializationResult = record {
    anima_id : principal;
    name : text;
    creation_time : nat64;
};

type UserState = variant {
    NotInitialized;
    Initialized : record {
        anima_id : principal;
        name : text;
    };
};

service : {
    create_anima : (text) -> (variant { Ok : InitializationResult; Err : Error });
    get_anima : (principal) -> (variant { Ok : Anima; Err : Error }) query;
    get_user_state : (opt principal) -> (UserState) query;
    check_initialization : (principal) -> (variant { Ok : bool; Err : Error }) query;
    interact : (principal, text) -> (variant { Ok : InteractionResult; Err : Error });
    set_openai_config : (text) -> (variant { Ok; Err : Error });
    toggle_autonomous : (principal, bool) -> (variant { Ok : bool; Err : Error });
    check_autonomous_messages : (principal) -> (variant { Ok : opt InteractionResult; Err : Error });
};