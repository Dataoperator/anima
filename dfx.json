{
  "canisters": {
    "anima": {
      "type": "rust",
      "package": "anima",
      "candid": "src/lib.did",
      "declarations": {
        "node_compatibility": true
      },
      "build": [
        "cargo build --target wasm32-unknown-unknown --release -p anima"
      ],
      "optimize": "O3",
      "gzip": true,
      "init_arg": "(record { admin = null; })",
      "metadata": [
        {
          "name": "candid:service",
          "visibility": "public"
        },
        {
          "name": "candid:args",
          "visibility": "public",
          "content": "file:src/constructor.did"
        },
        {
          "name": "https_outcalls",
          "content": "{\"allowed_methods\": [\"GET\", \"POST\"], \"allowed_headers\": [\"Accept\", \"Accept-Language\", \"Authorization\", \"Content-Language\", \"Content-Type\", \"OpenAI-Beta\"], \"cycles_per_call\": 800000000000, \"cycles_per_byte\": 50, \"max_request_bytes\": 4096, \"max_response_bytes\": 5242880, \"timeout_secs\": 30, \"permitted_origins\": null, \"urls\": [\"https://api.openai.com/v1/chat/completions\"]}"
        }
      ]
    },
    "anima_assets": {
      "type": "assets",
      "source": ["dist/"],
      "dependencies": ["anima"],
      "declarations": {
        "node_compatibility": true
      },
      "build": ["npm run build"],
      "init_arg": "(record { max_pages_per_asset = 1000 : nat16; })",
      "gzip": true,
      "headers": {
        "**/*": {
          "Cache-Control": "max-age=604800",
          "Strict-Transport-Security": "max-age=31536000; includeSubDomains",
          "X-Frame-Options": "DENY",
          "X-Content-Type-Options": "nosniff",
          "Content-Security-Policy": "default-src 'self' 'unsafe-eval' 'unsafe-inline' https://*.icp0.io; img-src 'self' data: https://*.icp0.io; connect-src 'self' https://*.icp0.io https://*.raw.icp0.io https://ic0.app",
          "Referrer-Policy": "strict-origin",
          "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
        }
      }
    }
  },
  "networks": {
    "ic": {
      "providers": ["https://ic0.app"],
      "type": "persistent"
    }
  },
  "version": 1
}